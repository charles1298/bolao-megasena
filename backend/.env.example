# ─── Servidor ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Banco de Dados ────────────────────────────────────────
DATABASE_URL=postgresql://bolao_user:SENHA_FORTE_AQUI@db:5432/bolao_megasena

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=GERE_COM_openssl_rand_-hex_64
JWT_REFRESH_SECRET=GERE_COM_openssl_rand_-hex_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS ──────────────────────────────────────────────────
# Domínio do frontend em produção (sem barra final)
FRONTEND_URL=https://seudominio.com.br

# ─── Mercado Pago ──────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_AQUI

# ─── Admin 2FA TOTP ────────────────────────────────────────
# Gerado automaticamente no primeiro setup do admin via /admin/setup-totp
ADMIN_TOTP_ISSUER=BolaoMegaSena

# ─── Preço por cartela (em centavos para evitar float) ─────
TICKET_PRICE_BRL=30.00

# ─── WhatsApp fallback (número do admin) ───────────────────
ADMIN_WHATSAPP=5511999999999

# ─── Logs ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
